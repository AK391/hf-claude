#!/usr/bin/env bash
# Claude launcher for Hugging Face Inference Providers with model/provider selection.
# Auth: uses $HF_TOKEN if set, else the token saved by `hf auth login`.
# fzf is used for selection when available, with an arrow-key menu fallback.

set -euo pipefail

# Parse wrapper flags, forwarding everything else to `claude`.
#   --bill-to <org> / --bill-to=<org>  bill inference to a HF org (X-HF-Bill-To)
#   --open-fusion                        auto-select the huggingface/open-fusion
#                                      Fusion-style orchestrator (skip the menu)
#   --all                              search the full Hub model catalog
#                                      (~17k text-generation models) instead of
#                                      opening the curated router list first
# Falls back to $HF_BILL_TO when the flag is absent.
BILL_TO="${HF_BILL_TO:-}"
USE_OPEN_FUSION=0
HUB_SEARCH="${HF_CLAUDE_ALL:-0}"
CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) exec claude --help ;;
    --bill-to)
      BILL_TO="${2:-}"
      if [[ -z "$BILL_TO" ]]; then
        echo "Error: --bill-to requires an organization name." >&2
        exit 1
      fi
      shift 2
      ;;
    --bill-to=*) BILL_TO="${1#*=}"; shift ;;
    --open-fusion) USE_OPEN_FUSION=1; shift ;;
    --all) HUB_SEARCH=1; shift ;;
    *) CLAUDE_ARGS+=("$1"); shift ;;
  esac
done

HF_TOKEN="${HF_TOKEN:-}"

# Fall back to the token saved by `hf auth login` when HF_TOKEN isn't set.
# `hf auth token` prints the active token and honors `hf auth switch`.
if [[ -z "$HF_TOKEN" ]] && command -v hf >/dev/null 2>&1; then
  HF_TOKEN="$(hf auth token 2>/dev/null || true)"
fi

if [[ -z "$HF_TOKEN" ]]; then
  echo "Error: no Hugging Face token found." >&2
  echo "Log in with:        hf auth login" >&2
  echo "or export a token:  export HF_TOKEN='hf_...'" >&2
  exit 1
fi

for cmd in curl jq claude; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: '$cmd' is required but not found in PATH." >&2
    exit 1
  fi
done

# Pick one line from stdin. Uses fzf when installed; otherwise falls back to a
# pure-bash arrow-key menu so fzf stays optional.
pick() {
  local prompt="$1" header="$2"
  if command -v fzf >/dev/null 2>&1; then
    fzf --prompt="$prompt" --height=50% --reverse --header="$header"
    return
  fi
  _arrow_menu "$header"
}

# Arrow-key selection menu (no fzf needed). Reads candidate lines from stdin,
# draws a scrolling list on the terminal (stderr) starting at the top, and
# prints the chosen line to stdout. Up/Down or j/k move, g/G or Home/End jump
# to ends, Enter selects, q/Esc/Ctrl-C cancel (prints nothing).
_arrow_menu() {
  local header="$1"
  local items=() line
  while IFS= read -r line; do items+=("$line"); done
  set +e  # interactive reads/arithmetic below may "fail" benignly under set -e
  local n=${#items[@]}
  (( n == 0 )) && return 0
  if [[ ! -t 2 || ! -r /dev/tty ]]; then
    echo "no-fzf menu needs an interactive terminal; install fzf for selection" >&2
    return 0
  fi

  local size rows cols
  size=$(stty size </dev/tty 2>/dev/null)
  rows=${size%% *}; cols=${size##* }
  [[ $rows =~ ^[0-9]+$ ]] || rows=24
  [[ $cols =~ ^[0-9]+$ ]] || cols=80
  local vh=$(( rows - 4 )) maxw=$(( cols - 4 ))
  (( vh < 1 ))   && vh=1
  (( vh > n ))   && vh=$n
  (( maxw < 8 )) && maxw=8

  local saved; saved=$(stty -g </dev/tty 2>/dev/null)
  trap 'stty "$saved" </dev/tty 2>/dev/null; printf "\e[?25h" >&2' EXIT
  trap 'stty "$saved" </dev/tty 2>/dev/null; printf "\e[?25h\n" >&2; exit 130' INT TERM
  stty -echo -icanon </dev/tty 2>/dev/null
  printf '\e[?25l' >&2   # hide cursor

  local sel=0 top=0 drawn=0 key rest i disp buf
  while true; do
    (( sel < top ))       && top=$sel
    (( sel >= top + vh )) && top=$(( sel - vh + 1 ))
    buf=""
    (( drawn )) && buf+=$'\e['"$(( vh + 2 ))"'A'
    drawn=1
    buf+=$'\r\e[2K\e[1m'"$header"$'\e[0m\n'
    for (( i = top; i < top + vh; i++ )); do
      disp=${items[i]:0:maxw}
      if (( i == sel )); then
        buf+=$'\r\e[2K\e[7m> '"$disp"$' \e[0m\n'
      else
        buf+=$'\r\e[2K  '"$disp"$'\n'
      fi
    done
    buf+=$'\r\e[2K\e[2m'"  [$(( sel + 1 ))/$n]  up/down move - enter select - q quit"$'\e[0m\n'
    printf '%s' "$buf" >&2

    IFS= read -rsn1 key </dev/tty || { sel=-1; break; }
    if [[ $key == $'\e' ]]; then
      # integer timeout: macOS stock bash 3.2 rejects fractional -t
      read -rsn2 -t 1 rest </dev/tty
      case "$rest" in
        '[A') (( sel > 0 ))     && sel=$(( sel - 1 )) ;;
        '[B') (( sel < n - 1 )) && sel=$(( sel + 1 )) ;;
        '[H') sel=0 ;;
        '[F') sel=$(( n - 1 )) ;;
        '')   sel=-1; break ;;          # bare Esc = cancel
      esac
    else
      case "$key" in
        k) (( sel > 0 ))     && sel=$(( sel - 1 )) ;;
        j) (( sel < n - 1 )) && sel=$(( sel + 1 )) ;;
        g) sel=0 ;;
        G) sel=$(( n - 1 )) ;;
        q|Q)            sel=-1; break ;;
        ''|$'\n'|$'\r') break ;;        # Enter = select current
      esac
    fi
  done

  printf '\e[%dA\r\e[J' "$(( vh + 2 ))" >&2   # erase the menu block
  stty "$saved" </dev/tty 2>/dev/null
  printf '\e[?25h' >&2
  trap - EXIT INT TERM

  (( sel < 0 )) && return 0
  printf '%s\n' "${items[sel]}"
}

# Minimal URL-encode for a query string (spaces -> +). The Hub /api/models
# search param accepts '+' for spaces; other shell-safe chars pass through.
_urlenc() {
  local s="$1" out="" i c
  for (( i = 0; i < ${#s}; i++ )); do
    c="${s:i:1}"
    case "$c" in
      [[:alnum:]._-~]) out+="$c" ;;
      ' ') out+='+' ;;
      *) printf -v c '%%%02X' "'$c"; out+="$c" ;;
    esac
  done
  printf '%s' "$out"
}

# Lowercase a string via tr (portable: macOS stock bash 3.2 has no ${var,,}).
_lower() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

# Fetch the Hugging Face Hub model catalog (text-generation models that have an
# inference provider) and print one model id per line. The router's /v1/models
# only exposes a ~123-model curated subset; the Hub endpoint has the full ~17k.
# Uses cursor pagination via the HTTP `Link: <url>; rel="next"` header (the
# cursor is an opaque base64 token, NOT the last model id). Walks all matching
# pages, capped at ~10 pages so a very broad query can't run unbounded.
#
# $1 = query string (optional; empty = whole catalog). Reads nothing; prints ids.
HUB_SEARCH_ENDPOINT="https://huggingface.co/api/models"
_hub_fetch() {
  local query="${1:-}" url enc
  url="${HUB_SEARCH_ENDPOINT}?inference_provider=all&pipeline_tag=text-generation&limit=1000"
  [[ -n "$query" ]] && enc="$(_urlenc "$query")" && url+="&search=${enc}"

  local hdr body next pages=0
  local max_pages="${HF_CLAUDE_HUB_MAX_PAGES:-10}"
  while [[ -n "$url" ]]; do
    (( pages >= max_pages )) && { echo "hf-claude: reached ${max_pages}-page search cap; showing first $(( pages * 1000 )) results. Narrow your query to see more." >&2; break; }
    hdr="$(mktemp -t hf-hub-hdr.XXXXXX)" || return 1
    body="$(mktemp -t hf-hub-body.XXXXXX)" || { rm -f "$hdr"; return 1; }
    if curl -fsS -D "$hdr" -o "$body" "$url"; then
      jq -r '.[].id' "$body" 2>/dev/null
    else
      echo "hf-claude: Hub catalog request failed for: $url" >&2
    fi
    # Next-page cursor lives in the Link header: <https://...>; rel="next".
    # Strip CR (curl -D keeps CRLF); pull the URL of the rel="next" relation.
    next="$(tr -d '\r' < "$hdr" | grep -i '^link:' \
      | grep -oE '<[^>]+>;[[:space:]]*rel="next"' \
      | sed -E 's/^<([^>]+)>;.*/\1/' | head -1)"
    rm -f "$hdr" "$body"
    url="$next"
    (( pages++ ))
  done
}

# Interactive Hub-catalog search. Prompts for a query on the tty, fetches
# matches, and lets the user pick one via `pick` (fzf if present, else
# `_filter_menu` which adds a type-to-filter step over `_arrow_menu` for large
# lists). Prints the chosen model id to stdout, or nothing if cancelled.
_hub_search() {
  local query result all_ids count
  [[ -t 2 && -r /dev/tty ]] || { echo "hf-claude: Hub search needs an interactive terminal." >&2; return 0; }
  printf '\e[1mSearch Hub models\e[0m (blank = whole catalog): ' >&2
  IFS= read -r query </dev/tty || query=""
  echo "" >&2

  all_ids="$(_hub_fetch "$query")"
  if [[ -z "$all_ids" ]]; then
    echo "hf-claude: no models matched \"${query}\"." >&2
    return 0
  fi
  count="$(printf '%s\n' "$all_ids" | grep -c .)"

  if command -v fzf >/dev/null 2>&1; then
    # fzf fuzzy-matches natively over the whole result set.
    printf '%s\n' "$all_ids" | fzf --prompt="Model: " --height=50% --reverse \
      --header="Hub catalog — ${count} matches for \"${query:-all}\""
    return $?
  fi
  # No fzf: hand off to the type-to-filter menu.
  printf '%s\n' "$all_ids" | _filter_menu "Hub catalog — ${count} matches for \"${query:-all}\""
}

# No-fzf fallback for a large, searchable list. Reads ids from stdin, prompts
# for a filter substring, narrows the set (case-insensitive substring), and
# hands the narrowed list to `_arrow_menu`. Loops: re-filter if the narrowed set
# is empty or the user cancels selection. Prints the chosen id, or nothing.
_filter_menu() {
  local header="$1" ids=() id filt match i
  while IFS= read -r id; do ids+=("$id"); done
  local n=${#ids[@]}
  (( n == 0 )) && return 0
  (( n == 1 )) && { printf '%s\n' "${ids[0]}"; return 0; }

  set +e
  if [[ ! -t 2 || ! -r /dev/tty ]]; then
    echo "hf-claude: interactive menu needs a terminal (install fzf for selection)." >&2
    return 0
  fi

  while true; do
    printf '\e[1mFilter\e[0m (%d models, blank=all): ' "$n" >&2
    IFS= read -r filt </dev/tty || filt=""
    echo "" >&2
    match=()
    if [[ -z "$filt" ]]; then
      match=("${ids[@]}")
    else
      local low; low="$(_lower "$filt")"
      local idlow
      for id in "${ids[@]}"; do
        idlow="$(_lower "$id")"
        [[ "$idlow" == *"$low"* ]] && match+=("$id")
      done
    fi
    if (( ${#match[@]} == 0 )); then
      echo "  no matches for \"${filt}\"; try another filter." >&2
      continue
    fi
    local choice
    choice="$(printf '%s\n' "${match[@]}" | _arrow_menu "$header")"
    if [[ -n "$choice" ]]; then
      printf '%s\n' "$choice"
      return 0
    fi
    # cancelled selection -> loop back to re-filter
  done
}

MODEL_DATA="$(curl -fsS "https://router.huggingface.co/v1/models" \
  -H "Authorization: Bearer ${HF_TOKEN}")"

# huggingface/open-fusion is a local Fusion-style orchestrator: it fans the prompt
# out to a panel of diverse models in parallel, then a single judge reads every
# panel answer, writes structured analysis, and streams the final unified answer
# grounded in it — in one pass, as OpenRouter's Fusion blog describes. It runs as
# a tiny local proxy; selecting it from the menu launches the proxy and points
# Claude Code at it. See hf_open_fusion.py.
OPEN_FUSION_ID="huggingface/open-fusion"
# Friendly menu label — the picker shows the bare id (the post-selection
# explainer screen describes the pipeline), so no inline description here. We
# map the label back to OPEN_FUSION_ID right after the menu resolves, so the
# rest of the script only ever sees the id.
OPEN_FUSION_MENU_LABEL="huggingface/open-fusion"
OPEN_FUSION_PROXY="${HF_OPEN_FUSION_PROXY:-}"

# Print a short explainer about what Open Fusion is, then wait for a keypress.
# Skipped when HF_OPEN_FUSION_SKIP_EXPLAINER=1, or when stderr isn't a TTY (so
# non-interactive / automated runs aren't blocked). Cancel with Ctrl-C before
# any key to abort without starting the proxy.
#
# $1 = preset name (quality|budget|speed|custom), $2 = comma-joined panel,
# $3 = comma-joined judge (judge in one-call mode, or analyst,synthesizer in
# two-stage), $4 = two_stage flag (1/0). Pulled live from the proxy's /health so
# the screen reflects the panel that will actually run.
_open_fusion_explainer() {
  [[ "${HF_OPEN_FUSION_SKIP_EXPLAINER:-0}" == "1" ]] && return 0
  [[ -t 2 ]] || return 0
  local preset="${1:-?}" panel="${2:-?}" judge="${3:-?}" two_stage="${4:-0}"
  local panel_pretty judge_pretty pipeline judge_label cost
  panel_pretty="$(printf '%s\n' "$panel" | tr ',' '\n' | sed 's/^/      • /')"
  judge_pretty="$(printf '%s\n' "$judge" | tr ',' '\n' | sed 's/^/      • /')"
  if [[ "$two_stage" == "1" ]]; then
    pipeline="      1. PANEL      — your prompt is sent to several diverse models in parallel
      2. ANALYST    — a model reads every panel answer and writes structured
                      analysis (consensus / contradictions / coverage / blind spots)
      3. SYNTHESIS  — a model streams the final unified answer, grounded in that"
    judge_label="Analyst + synthesizer (fuse the panel into the final answer)"
    cost="Cost: a turn is billed as (panel tokens) + (analyst tokens) + (synthesis
    tokens), against your HF token / --bill-to org."
  else
    pipeline="      1. PANEL   — your prompt is sent to several diverse models in parallel
      2. JUDGE   — ONE model reads every panel answer, writes structured analysis
                   (consensus / contradictions / coverage / blind spots), then
                   streams the final unified answer grounded in it — in a single
                   pass, as OpenRouter's Fusion blog describes"
    judge_label="Judge (reads the panel, then writes the final answer — one pass)"
    cost="Cost: a turn is billed as (panel tokens) + (judge tokens), against your
    HF token / --bill-to org."
  fi
  cat >&2 <<EOF
🤗  huggingface/open-fusion — OpenRouter Fusion-style orchestrator

    Instead of one model answering your prompt, Open Fusion runs the Fusion
    pipeline that OpenRouter found surpasses single frontier models:

${pipeline}

    Preset: ${preset}   (panel size fixed at 3 — matches OpenRouter's Fusion)

    Panel (the 3 models that will answer in parallel):
${panel_pretty}

    ${judge_label}:
${judge_pretty}

    ${cost}

    Logs: /tmp/hf-open-fusion.log   •   Proxy: 127.0.0.1:8080

  Press Enter to continue · Ctrl-C to cancel
EOF
  printf '\e[?25l' >&2   # hide cursor while waiting
  local key
  IFS= read -rsn1 key </dev/tty || key=""
  printf '\e[?25h' >&2   # show cursor again
  echo "" >&2
}

_find_open_fusion_proxy() {
  # Explicit override wins; otherwise look next to this script, then on PATH.
  if [[ -n "$OPEN_FUSION_PROXY" ]]; then
    [[ -f "$OPEN_FUSION_PROXY" ]] && { echo "$OPEN_FUSION_PROXY"; return 0; }
    return 1
  fi
  local here
  here="$(cd "$(dirname "$0")" && pwd)/hf_open_fusion.py"
  [[ -f "$here" ]] && { echo "$here"; return 0; }
  command -v hf_open_fusion.py >/dev/null 2>&1 && { command -v hf_open_fusion.py; return 0; }
  return 1
}

SEARCH_HUB_ENTRY="🔍 Search the full Hub catalog…"
MODEL_ORIGIN="router"

if [[ "$USE_OPEN_FUSION" == "1" ]]; then
  MODEL="$OPEN_FUSION_ID"
  MODEL_ORIGIN="open-fusion"
elif [[ "$HUB_SEARCH" == "1" ]]; then
  # --all: open straight into the Hub search prompt. Cancel falls back to the
  # curated router list so the user is never left with no way to pick a model.
  MODEL="$(_hub_search)"
  if [[ -z "$MODEL" ]]; then
    MODEL="$(printf '%s\n' "$OPEN_FUSION_MENU_LABEL" \
      | cat - <(echo "$MODEL_DATA" | jq -r '.data[].id') \
      | pick "Model: " "Hugging Face Inference Providers - Select Model")"
  else
    MODEL_ORIGIN="hub"
  fi
else
  # Default: Open Fusion is the preselected (first) entry, with the Hub search
  # entry and the curated router list below it. Open Fusion comes first so the
  # picker highlights it by default; its explainer screen (shown after) describes
  # the pipeline, so the picker line stays bare.
  MODEL="$(printf '%s\n' "$OPEN_FUSION_MENU_LABEL" "$SEARCH_HUB_ENTRY" \
    | cat - <(echo "$MODEL_DATA" | jq -r '.data[].id') \
    | pick "Model: " "Hugging Face Inference Providers - Select Model")"
  if [[ "$MODEL" == "$SEARCH_HUB_ENTRY" ]]; then
    MODEL="$(_hub_search)"
    if [[ -n "$MODEL" ]]; then
      MODEL_ORIGIN="hub"
    else
      MODEL=""   # search cancelled; treat as no selection below
    fi
  fi
fi

# The menu shows the friendly 🤗 label; collapse it back to the bare id so the
# rest of the script (provider routing, MODEL_STRING, open-fusion startup) only
# ever compares against OPEN_FUSION_ID.
[[ "$MODEL" == "$OPEN_FUSION_MENU_LABEL" ]] && MODEL="$OPEN_FUSION_ID"

if [[ -z "$MODEL" ]]; then
  echo "No model selected"
  exit 1
fi

if [[ "$MODEL" == "$OPEN_FUSION_ID" ]]; then
  # Three presets mirror OpenRouter Fusion's three (general-high / -budget /
  # -fast): Quality, Budget, Speed. Each is a fixed-size (3) diverse panel. The
  # panel composition changes, the size stays 3. HF_OPEN_FUSION_PRESET set in the
  # env skips the picker; so does any non-interactive run (defaulting to Speed,
  # which keeps --open-fusion's "skip the menu" promise).
  OPEN_FUSION_PRESET="${HF_OPEN_FUSION_PRESET:-}"
  if [[ -z "$OPEN_FUSION_PRESET" && -t 2 ]]; then
    OPEN_FUSION_PRESET="$(printf '%s\n' \
      "quality  🏆 — strongest panel (MiniMax-M3, DeepSeek-V3, Kimi-K2.6)" \
      "budget   💰 — cheap-but-capable (Ornith-1.0-35B, Qwen3.6-35B-A3B, gemma-4-31B)" \
      "speed    ⚡ — fast small panel (Qwen2.5-7B, Llama-3.1-8B, Olmo-3-7B)" \
      | pick "Preset: " "huggingface/open-fusion — Fusion preset (panel of 3)" )"
    # The picker returns the whole line; take the first whitespace-delimited token.
    OPEN_FUSION_PRESET="${OPEN_FUSION_PRESET%% *}"
  fi
  [[ -z "$OPEN_FUSION_PRESET" ]] && OPEN_FUSION_PRESET="speed"
  case "$OPEN_FUSION_PRESET" in
    quality|budget|speed) : ;;  # valid
    *) echo "Unknown preset: ${OPEN_FUSION_PRESET} (use quality|budget|speed)" >&2; exit 1 ;;
  esac
  export HF_OPEN_FUSION_PRESET="$OPEN_FUSION_PRESET"

  PROXY_SCRIPT="$(_find_open_fusion_proxy || true)"
  if [[ -z "$PROXY_SCRIPT" ]]; then
    echo "Error: selected huggingface/open-fusion but hf_open_fusion.py was not found." >&2
    echo "       Set HF_OPEN_FUSION_PROXY=/path/to/hf_open_fusion.py or install it next to this script." >&2
    exit 1
  fi
  command -v python3 >/dev/null 2>&1 || { echo "Error: python3 is required to run the open-fusion proxy." >&2; exit 1; }

  # Prefer a venv bundled with the extension (deps isolated from system Python),
  # falling back to the system python3 if it happens to have the deps.
  HERE="$(cd "$(dirname "$0")" && pwd)"
  if [[ -x "$HERE/.venv/bin/python" ]]; then
    PY="$HERE/.venv/bin/python"
  elif [[ -x "$HOME/.hf-open-fusion-venv/bin/python" ]]; then
    PY="$HOME/.hf-open-fusion-venv/bin/python"
  else
    PY="python3"
  fi

  PORT="${HF_OPEN_FUSION_PORT:-8080}"
  # If a proxy is already running but on a DIFFERENT preset, restart it so the
  # chosen panel takes effect. A proxy picks its panel at import time from the
  # env, so a long-lived one won't see a preset change without a restart.
  _RUNNING_PRESET="$(curl -fsS "http://127.0.0.1:${PORT}/health" 2>/dev/null | jq -r '.preset // empty' 2>/dev/null || true)"
  # Restart the running proxy unless it positively confirms it's on our preset.
  # A proxy picks its panel at import time from the env, so a long-lived one
  # won't see a preset change without a restart. Two cases force a restart:
  #   (1) it reports a DIFFERENT preset than the one we just selected, or
  #   (2) a proxy is up but reports NO preset — a stale/older build (or one
  #       started before preset support) whose panel we can't verify. Reusing
  #       it would silently run the wrong panel, so restart to be safe.
  _RESTART=0
  if [[ -n "$_RUNNING_PRESET" && "$_RUNNING_PRESET" != "$OPEN_FUSION_PRESET" ]]; then
    echo "→ switching Open Fusion preset ${_RUNNING_PRESET} → ${OPEN_FUSION_PRESET}; restarting proxy" >&2
    _RESTART=1
  elif [[ -z "$_RUNNING_PRESET" ]] && curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
    echo "→ running open-fusion proxy doesn't report a preset; restarting on ${OPEN_FUSION_PRESET}" >&2
    _RESTART=1
  fi
  if [[ "$_RESTART" == "1" ]]; then
    # Kill every process bound to the port so the new preset can take it. A
    # stale proxy may be multiple processes (parent + workers); killing only
    # the first leaves workers holding the port. lsof is standard on macOS;
    # fall back to a no-op kill if it's absent.
    if command -v lsof >/dev/null 2>&1; then
      _RUNNING_PIDS="$(lsof -ti tcp:${PORT} 2>/dev/null || true)"
      [[ -n "$_RUNNING_PIDS" ]] && kill $_RUNNING_PIDS 2>/dev/null || true
    fi
    # Wait for the old proxy to release the port.
    for _ in $(seq 1 50); do
      curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1 || break
      sleep 0.1
    done
  fi
  # Reuse a running proxy on the port if one is already listening (and matched).
  if ! curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
    echo "→ starting huggingface/open-fusion proxy on 127.0.0.1:${PORT} (preset: ${OPEN_FUSION_PRESET})" >&2
    "$PY" "$PROXY_SCRIPT" >/tmp/hf-open-fusion.log 2>&1 &
    OPEN_FUSION_PID=$!
    # Wait until it accepts /health, but give up after ~10s.
    for _ in $(seq 1 100); do
      if curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then break; fi
      kill -0 "$OPEN_FUSION_PID" 2>/dev/null || { echo "Error: open-fusion proxy exited during startup. See /tmp/hf-open-fusion.log" >&2; exit 1; }
      sleep 0.1
    done
  fi
  curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1 || {
    echo "Error: open-fusion proxy is not responding on 127.0.0.1:${PORT}." >&2
    echo "       Check /tmp/hf-open-fusion.log or set HF_OPEN_FUSION_PORT." >&2
    exit 1
  }
  # Pull the resolved panel + judge from /health so the explainer shows the
  # exact 3 panel models + judge(s) the proxy will use this session. In one-call
  # mode (default) that's a single judge; in two-stage mode it's analyst,synthesizer.
  _HEALTH_JSON="$(curl -fsS "http://127.0.0.1:${PORT}/health" 2>/dev/null || echo '{}')"
  _RESOLVED_PRESET="$(printf '%s' "$_HEALTH_JSON" | jq -r '.preset // "?"')"
  _RESOLVED_PANEL="$(printf '%s' "$_HEALTH_JSON" | jq -r '.panel | join(",")')"
  _RESOLVED_TWO_STAGE="$(printf '%s' "$_HEALTH_JSON" | jq -r 'if .two_stage then "1" else "0" end')"
  if [[ "$_RESOLVED_TWO_STAGE" == "1" ]]; then
    _RESOLVED_JUDGE="$(printf '%s' "$_HEALTH_JSON" | jq -r '[.analyst, .synthesizer] | join(",")')"
  else
    _RESOLVED_JUDGE="$(printf '%s' "$_HEALTH_JSON" | jq -r '.judge // .analyst // "?"')"
  fi
  # Show what Open Fusion is before committing to it; cancel here (Ctrl-C) to
  # bail out. HF_OPEN_FUSION_SKIP_EXPLAINER=1 / non-TTY skips it.
  _open_fusion_explainer "$_RESOLVED_PRESET" "$_RESOLVED_PANEL" "$_RESOLVED_JUDGE" "$_RESOLVED_TWO_STAGE"
  MODEL_STRING="$OPEN_FUSION_ID"
  PROVIDER="open-fusion"
else
  if [[ "$MODEL_ORIGIN" == "hub" ]]; then
    # A model chosen from the Hub catalog: the Hub /api/models response carries
    # no per-provider list, so we can't offer a provider menu. Route with the
    # bare model id and let the router pick the serving provider (:fastest).
    PROVIDER="auto"
    MODEL_STRING="$MODEL"
    echo "→ using auto provider routing for Hub model: ${MODEL}" >&2
  else
    PROVIDER="$(
      {
        echo "auto"
        echo "$MODEL_DATA" | jq -r --arg model "$MODEL" '.data[] | select(.id == $model) | .providers[].provider'
      } | awk '!seen[$0]++' \
        | pick "Provider: " "Select Provider for ${MODEL} (auto = no suffix)"
    )"

    if [[ -z "$PROVIDER" ]]; then
      echo "No provider selected"
      exit 1
    fi

    if [[ "$PROVIDER" == "auto" ]]; then
      MODEL_STRING="$MODEL"
    else
      MODEL_STRING="${MODEL}:${PROVIDER}"
    fi
  fi
fi

echo "→ claude @ ${MODEL_STRING}" >&2

export ANTHROPIC_API_KEY="$HF_TOKEN"
export ANTHROPIC_AUTH_TOKEN="$HF_TOKEN"
if [[ "$MODEL" == "$OPEN_FUSION_ID" ]]; then
  # Route Claude Code through the local open-fusion proxy instead of the router.
  export ANTHROPIC_BASE_URL="http://127.0.0.1:${PORT}"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$OPEN_FUSION_ID"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="$OPEN_FUSION_ID"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$OPEN_FUSION_ID"
else
  export ANTHROPIC_BASE_URL="https://router.huggingface.co"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$MODEL_STRING"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="$MODEL_STRING"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$MODEL_STRING"
fi

# Bill inference to a HF org via the router's X-HF-Bill-To header. Appended so
# any user-supplied ANTHROPIC_CUSTOM_HEADERS are preserved.
if [[ -n "$BILL_TO" ]]; then
  if [[ -n "${ANTHROPIC_CUSTOM_HEADERS:-}" ]]; then
    export ANTHROPIC_CUSTOM_HEADERS="${ANTHROPIC_CUSTOM_HEADERS}
X-HF-Bill-To: ${BILL_TO}"
  else
    export ANTHROPIC_CUSTOM_HEADERS="X-HF-Bill-To: ${BILL_TO}"
  fi
  echo "→ billing to org: ${BILL_TO}" >&2
fi

exec claude --model "$MODEL_STRING" ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
